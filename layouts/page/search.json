{{- /* 1. 使用新版统一的页面获取方式 */ -}}
{{- $pages := partial "helper/pages.html" .Site.Home -}}
{{- $result := slice -}}

{{- range $pages -}}
    {{- $title := .Title -}}
    {{- $permalink := .RelPermalink -}}
    {{- $type := "article" -}}

    {{- /* 2. 恢复你的核心逻辑：特殊处理“说说”分类 */ -}}
    {{- if eq .Section "shuoshuo" -}}
        {{- $type = "shuoshuo" -}}
        {{- if .Title -}}
            {{- $title = print "💬 " .Title -}}
        {{- else -}}
            {{- $title = print "💬 " (.Plain | truncate 15) -}}
        {{- end -}}
    {{- end -}}

    {{- $data := dict "title" $title "date" .Date "permalink" $permalink "content" (.Plain) "type" $type -}}

    {{- /* 3. 使用新版图片处理函数（包含 Context 参数） */ -}}
    {{- $image := partial "helper/image" (dict "Image" .Params.image "Resources" .Resources "Context" .) -}}
    {{- if $image -}}
        {{- $data = merge $data (dict "image" $image.Permalink) -}}
    {{- end -}}

    {{- $result = $result | append $data -}}
{{- end -}}

{{ jsonify $result }}